  {
    "id": "n2_00009",
    "tier": "S",
    "basic": {
      "word": "遠慮",
      "kana": "えんりょ",
      "jlpt_level": "N2",
      "part_of_speech": [
        "名词",
        "サ变动词"
      ],
      "meanings_cn": [
        {
          "cn": "客气",
          "priority": 1
        },
        {
          "cn": "谢绝",
          "priority": 2
        }
      ],
      "core_meaning": "克制自己不给别人添麻烦"
    },
    "nuance": {
      "core_nuance": "日本人社交的润滑剂。远慮する可以是客气（不打扰别人），也可以是谢绝（委婉拒绝）。中国人容易误解成疏远。",
      "formality": 3,
      "emotion": "中性"
    },
    "examples": {
      "sentences": [
        {
          "jp": "遠慮しないで、もっと食べて。",
          "cn": "别客气，多吃点。",
          "scene": "招待客人",
          "style": "spoken"
        },
        {
          "jp": "お酒は遠慮しておきます。",
          "cn": "酒我就谢绝了。",
          "scene": "婉拒劝酒",
          "style": "spoken"
        },
        {
          "jp": "ここでの喫煙はご遠慮ください。",
          "cn": "这里请勿吸烟。",
          "scene": "公共场所",
          "style": "written"
        }
      ]
    },
    "usage": {
      "is_spoken": true,
      "is_written": true,
      "is_formal": true,
      "is_casual": true,
      "is_business": true,
      "common_in_daily_life": true,
      "common_in_news": false,
      "collocations": [
        {
          "pattern": "ご遠慮ください",
          "meaning_cn": "请勿…",
          "frequency": "高"
        },
        {
          "pattern": "遠慮する",
          "meaning_cn": "客气/谢绝",
          "frequency": "高"
        }
      ],
      "conjugal_forms": null
    },
    "mistakes": {
      "common_mistakes": [
        {
          "type": "意思",
          "wrong": "遠慮就是疏远。",
          "correct": "遠慮是克制自己不给别人添麻烦，是礼貌的表现。",
          "explanation": "中文的客气有时暗示疏远，但日语遠慮是正面的社交礼仪。"
        },
        {
          "type": "用法",
          "wrong": "用遠慮来表达不喜欢。",
          "correct": "遠慮する是委婉拒绝，不是表达不喜欢。",
          "explanation": "日本人说「遠慮しておきます」是在礼貌地拒绝，不是说不喜欢。"
        }
      ],
      "confused_with": [
        {
          "word": "断る",
          "diff": "断る是直接拒绝，遠慮是委婉拒绝"
        }
      ]
    },
    "memory": {
      "memory_hint": "远=远，虑=考虑。考虑得远→克制自己→客气。",
      "image_scene": "一个人面对美食，虽然很想吃但因为礼貌而克制",
      "chinese_memory_trick": "中文的客气有时暗示疏远，日语遠慮是正面的社交礼仪。"
    },
    "culture": {
      "japan_culture_note": "日本人从小被教育要遠慮，不要给别人添麻烦。",
      "social_context": "远慮是日本社交的基本功。",
      "japanese_workplace_note": "新人入职第一天就要学会遠慮。"
    },
    "relations": {
