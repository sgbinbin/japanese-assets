          "meaning_cn": "不会读空气",
          "frequency": "高"
        }
      ],
      "conjugal_forms": null
    },
    "mistakes": {
      "common_mistakes": [
        {
          "type": "文化",
          "wrong": "空気を読む就是看别人脸色。",
          "correct": "空気を読む是主动感知氛围，不是被动讨好。",
