        {
          "jp": "彼、いきなり反対意見言うけど、根回しが下手なんだよね。",
          "cn": "他动不动就提反对意见，但其实私下沟通能力很差。",
          "scene": "评价同事",
          "style": "spoken"
        },
        {
          "jp": "日本では根回しをしないと物事が進まないことが多い。",
          "cn": "在日本不提前打招呼的话，事情往往推不动。",
          "scene": "解释文化",
          "style": "written"
        }
